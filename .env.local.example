# ============================================
# PPT-Transformer 环境变量配置
# ============================================

# ---------------------------------------------
# 必需配置
# ---------------------------------------------

# Google Gemini API Key (必需)
# 用于内容分析和幻灯片生成
# 获取方式: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ---------------------------------------------
# 图片生成配置（可选但推荐）
# ---------------------------------------------

# Together.ai Image Generation API
# 官网: https://www.together.ai/
# API 文档: https://docs.together.ai/docs/quickstart
#
# TOGETHER_API_KEY: Together.ai 的 API Key
#
# 获取 API Key 的方法:
# 1. 注册 https://api.together.xyz/signup
# 2. 访问 https://api.together.xyz/settings/api-keys
# 3. 创建新的 API Key 并复制
#
# 免费额度: $5 (约 500 张图片)
# 价格: $0.015/张 (1024×1024, Flux Schnell 模型)
# 模型: black-forest-labs/FLUX.1-schnell (Serverless)
#
# 如果不配置，系统将使用 SVG 占位符图片
#
TOGETHER_API_KEY=your_together_api_key_here

# ---------------------------------------------
# 部署说明
# ---------------------------------------------

# 1. 本地开发:
#    - 复制此文件为 .env.local
#    - 填写 GEMINI_API_KEY
#    - 可选：填写 TOGETHER_API_KEY 启用图片生成

# 2. Vercel 部署:
#    - 在 Vercel 项目设置 > Environment Variables 中添加:
#      * GEMINI_API_KEY (必需)
#      * TOGETHER_API_KEY (可选，用于图片生成)
#    - Together.ai 原生支持 Serverless，无需额外部署

# 3. Docker 部署:
#    - 使用 docker-compose.yml 或 Dockerfile
#    - 在 .env 文件中配置环境变量
#    - 支持所有云平台 (Railway, Render, Fly.io 等)
