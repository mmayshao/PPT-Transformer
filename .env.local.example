# 即梦AI Free API Configuration
# 项目地址: https://github.com/LLM-Red-Team/jimeng-free-api
#
# JIMENG_API_KEY: 即梦AI的sessionid (从浏览器Cookie中获取)
# JIMENG_API_BASE: API服务地址 (默认 http://localhost:8000)
#
# 获取sessionid的方法:
# 1. 登录 https://jimeng.jianying.com/
# 2. 打开浏览器开发者工具 (F12)
# 3. 在Application > Cookies中找到sessionid的值
#
JIMENG_API_KEY=your_jimeng_sessionid_here
JIMENG_API_BASE=http://localhost:8000
